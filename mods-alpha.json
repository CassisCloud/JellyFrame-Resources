[
  {
    "id": "jelly-assistant",
    "name": "JellyAssistant",
    "author": "grimmdev",
    "description": "High-speed free AI chat via OpenRouter. Use :free models for no-cost chatting.",
    "version": "1.4.0",
    "jellyfin": "10.11+",
    "tags": ["ui", "ai", "free", "openrouter", "assistant"],
    "jsUrl": "https://raw.githubusercontent.com/Jellyfin-PG/JellyFrame-Resources/refs/heads/main/mods/jelly-assistant-client.js",
    "serverJs": "https://raw.githubusercontent.com/Jellyfin-PG/JellyFrame-Resources/refs/heads/main/mods/jelly-assistant-server.js",
    "permissions": ["http", "jellyfin.read"],
    "requires": [],
    "vars": [
      {
        "key": "API_URL",
        "name": "OpenRouter API URL",
        "type": "text",
        "default": "https://openrouter.ai/api/v1/chat/completions"
      },
      {
        "key": "API_KEY",
        "name": "OpenRouter API Key",
        "type": "text",
        "default": ""
      },
      {
        "key": "MODEL",
        "name": "Model Name",
        "type": "text",
        "default": "openrouter/free"
      }
    ]
  }
]
